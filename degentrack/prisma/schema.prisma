generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model GroupTokenCall {
  id       String   @id
  groupId  BigInt
  mint     String
  symbol   String   @default("")
  name     String   @default("")
  calledAt DateTime @default(now())

  @@index([groupId, calledAt])
  @@index([groupId, mint])
}

model Trade {
  id            String   @id
  walletAddress String
  type          String
  tokenMint     String
  tokenSymbol   String
  tokenName     String   @default("")
  tokenAmount   Float
  priceUsd      Float    @default(0)
  totalUsd      Float    @default(0)
  marketCapUsd  Float    @default(0)
  solAmount     Float    @default(0)
  signature     String   @unique
  timestamp     DateTime @default(now())
  Wallet        Wallet   @relation(fields: [walletAddress], references: [address])

  @@index([walletAddress, timestamp])
  @@index([walletAddress, tokenMint])
}

model User {
  id            BigInt          @id
  username      String?
  minTradeSize  Float           @default(0)
  firstSeen     DateTime        @default(now())
  lastSeen      DateTime
  WatchedWallet WatchedWallet[]
}

model Wallet {
  address       String          @id
  Trade         Trade[]
  WatchedWallet WatchedWallet[]
}

model WatchedWallet {
  userId        BigInt
  walletAddress String
  label         String?
  tags          String[] @default([])
  paused        Boolean  @default(false)
  minTradeSize  Float?
  User          User     @relation(fields: [userId], references: [id])
  Wallet        Wallet   @relation(fields: [walletAddress], references: [address])

  @@id([userId, walletAddress])
}
